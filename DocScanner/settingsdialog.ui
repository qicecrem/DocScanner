  <property name="styleSheet">
   <string notr="true">/* 基础对话框背景 */
QDialog { background-color: #1e1e1e; font-family: &quot;Microsoft YaHei&quot;; }

/* 标签文字 */
QLabel { color: #cccccc; font-size: 13px; font-weight: bold; }

/* 选项卡容器与面板 */
QTabWidget::pane { border: 1px solid #3a3a3a; background: #252525; border-radius: 6px; top: -1px; }
QTabBar::tab { background: #1e1e1e; color: #888888; padding: 10px 20px; border: 1px solid #3a3a3a; border-bottom: none; border-top-left-radius: 6px; border-top-right-radius: 6px; margin-right: 2px; font-weight: bold; font-size: 13px; }
QTabBar::tab:selected { background: #252525; color: #ffffff; border-bottom: 1px solid #252525; }
QTabBar::tab:hover:!selected { background: #2a2a2a; color: #aaaaaa; }

/* 输入框 */
QLineEdit { background-color: #181818; color: #ffffff; border: 1px solid #444444; border-radius: 4px; padding: 6px 10px; font-size: 12px; }
QLineEdit:focus { border: 1px solid #0078d4; }

/* 按钮组合 */
QPushButton { background-color: #333333; color: white; border: none; border-radius: 4px; padding: 8px 15px; font-size: 13px; font-weight: bold; }
QPushButton:hover { background-color: #444444; }
QPushButton:pressed { background-color: #222222; }

/* 主题色按钮 (如浏览按钮) */
QPushButton#btnBrowseModel, QPushButton#btnBrowseTess { background-color: #0078d4; }
QPushButton#btnBrowseModel:hover, QPushButton#btnBrowseTess:hover { background-color: #3298fe; }

/* 下拉框与微调框 */
QComboBox, QSpinBox { background-color: #181818; color: white; border: 1px solid #444444; border-radius: 4px; padding: 6px 10px; font-size: 13px; }
QComboBox::drop-down, QSpinBox::up-button, QSpinBox::down-button { border: none; }
QComboBox QAbstractItemView { background-color: #181818; color: white; selection-background-color: #0078d4; border: 1px solid #444444; }</string>
