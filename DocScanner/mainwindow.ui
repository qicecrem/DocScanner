  <property name="styleSheet">
   <string notr="true">/* ======== 全局背景与字体 ======== */
QMainWindow { background-color: #181818; font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;; }
QLabel { color: #d0d0d0; font-size: 13px; font-weight: bold; }

/* ======== 左侧面板与容器 ======== */
QFrame#controlFrame { background-color: #202020; border-right: 1px solid #2d2d2d; }
QGroupBox { font-weight: bold; border: 1px solid #333333; border-radius: 6px; margin-top: 12px; padding-top: 15px; background-color: #252525; }
QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; left: 10px; color: #aaaaaa; padding: 0 5px; }

/* ======== 横向缩略图列表 ======== */
QListWidget#thumbnailList { background-color: #1a1a1a; border: 1px solid #333; border-radius: 6px; padding: 5px; }
QListWidget#thumbnailList::item { color: #aaaaaa; border-radius: 4px; border: 2px solid transparent; }
QListWidget#thumbnailList::item:selected { border: 2px solid #0e639c; background-color: #2a2d30; color: #ffffff; }

/* ======== 极简低饱和度按钮 ======== */
QPushButton { background-color: #333333; color: #dddddd; border: 1px solid #444444; border-radius: 5px; font-size: 13px; padding: 8px; font-weight: bold; }
QPushButton:hover { background-color: #404040; border-color: #555555; }
QPushButton:pressed { background-color: #222222; }
QPushButton:disabled { background-color: #1e1e1e; color: #555555; border-color: #2a2a2a; }

/* 核心强调操作使用低饱和度科技蓝 */
QPushButton#btnScanAI, QPushButton#btnCrop, QPushButton#btnExportPDF { background-color: #0e639c; color: white; border-color: #1177bb; }
QPushButton#btnScanAI:hover, QPushButton#btnCrop:hover, QPushButton#btnExportPDF:hover { background-color: #1177bb; border-color: #1ebaff; }
QPushButton#btnExportPDF { font-size: 14px; }

/* ======== 输入框与下拉框 ======== */
QComboBox { background-color: #1a1a1a; color: #cccccc; border: 1px solid #444; border-radius: 4px; padding: 5px 10px; }
QComboBox::drop-down { border: none; }
QComboBox QAbstractItemView { background-color: #1a1a1a; color: white; selection-background-color: #0e639c; border: 1px solid #555; }

/* ======== 滑动条 ======== */
QSlider::groove:horizontal { border: 1px solid #333; height: 6px; background: #1a1a1a; border-radius: 3px; }
QSlider::handle:horizontal { background: #666666; width: 14px; margin: -4px 0; border-radius: 7px; }
QSlider::handle:horizontal:hover { background: #0e639c; }

/* ======== 分屏器拖动条 ======== */
QSplitter::handle { background-color: #2d2d2d; margin: 2px; border-radius: 2px; }
QSplitter::handle:vertical { height: 4px; }
QSplitter::handle:horizontal { width: 4px; }
QSplitter::handle:hover { background-color: #0e639c; }</string>
